# Digital Manufacturing Academy — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to a public repository.

# ─── Required ──────────────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens. Keep it secret.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# ─── MySQL / Hostinger ─────────────────────────────────────────────────────────
# Your Hostinger MySQL connection string.
# Find credentials in: Hostinger hPanel → Databases → MySQL Databases
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
MYSQL_DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# ─── AI Tutor — Optional ───────────────────────────────────────────────────────
# Free key at: https://aistudio.google.com/app/apikey
# Without this the AI tutor runs in demo/mock mode (still works fine).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
